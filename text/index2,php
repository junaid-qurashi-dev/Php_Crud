    <script>
      $(document).ready(function () {
        // Load first page
        loaddata(1);

        /* ===============================
               DELETE STUDENT
            =============================== */

        $(document).on("click", ".delete_btn", function () {
          var stu_id = $(this).closest("tr").find(".stu_id").text();
          $("#delete_id").val(stu_id);
          $("#DeleteModal").modal("show");
        });

        $(".student_delete_ajax").click(function (e) {
          e.preventDefault();

          var stu_id = $("#delete_id").val();

          $.ajax({
            url: "Crud/code.php",
            type: "POST",
            data: {
              checking_delete: true,
              stu_id: stu_id,
            },
            success: function (response) {
              $("#DeleteModal").modal("hide");

              $(".message-show").html(`
                    <div class="alert alert-success alert-dismissible fade show">
                        <strong>Success!</strong> ${response}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                `);

              loaddata(1);
            },
          });
        });

        /* ===============================
               ADD STUDENT
            =============================== */

        $(".student_add").click(function (e) {
          e.preventDefault();

          var fname = $(".fname").val();
          var lname = $(".lname").val();
          var stu_class = $(".class").val();
          var section = $(".section").val();
          var status = $(".status").val();

          if (fname && lname && stu_class && section && status) {
            $.ajax({
              type: "POST",
              url: "Crud/code.php",
              data: {
                checking_add: true,
                fname: fname,
                lname: lname,
                class: stu_class,
                section: section,
                status: status,
              },
              success: function (response) {
                $("#student_AddModal").modal("hide");

                $(".message-show").html(`
                        <div class="alert alert-success alert-dismissible fade show">
                            <strong>Success!</strong> ${response}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    `);

                $(".fname, .lname, .class, .section, .status").val("");
                loaddata(1);
              },
            });
          } else {
            alert("Please fill all fields!");
          }
        });

        /* ===============================
               VIEW STUDENT
            =============================== */

        $(document).on("click", ".viewbtn", function () {
          var stu_id = $(this).closest("tr").find(".stu_id").text();

          $.ajax({
            url: "Crud/code.php",
            type: "POST",
            dataType: "json",
            data: {
              checking_view: true,
              stu_id: stu_id,
            },
            success: function (response) {
              $(".id_view").text(response.id);
              $(".fname_view").text(response.fname);
              $(".lname_view").text(response.lname);
              $(".class_view").text(response.class);
              $(".section_view").text(response.section);

              if (response.status == "active") {
                $(".status_view").html(
                  '<span class="badge bg-success">Active</span>',
                );
              } else {
                $(".status_view").html(
                  '<span class="badge bg-danger">InActive</span>',
                );
              }
              $("#ViewModal").modal("show");
            },
          });
        });

        /* ===============================
               EDIT STUDENT (LOAD DATA)
            =============================== */

        $(document).on("click", ".edit_btn", function () {
          var stu_id = $(this).closest("tr").find(".stu_id").text();

          $.ajax({
            url: "Crud/code.php",
            type: "POST",
            dataType: "json",
            data: {
              checking_edit: true,
              stu_id: stu_id,
            },
            success: function (response) {
              $("#edit_id").val(response.id);
              $("#edit_fname").val(response.fname);
              $("#edit_lname").val(response.lname);
              $("#edit_class").val(response.class);
              $("#edit_section").val(response.section);
              $("#edit_status").val(response.status);

              $("#EditModal").modal("show");
            },
          });
        });

        /* ===============================
               UPDATE STUDENT
            =============================== */

        $(".student_update_ajax").click(function (e) {
          e.preventDefault();

          var stu_id = $("#edit_id").val();
          var fname = $("#edit_fname").val();
          var lname = $("#edit_lname").val();
          var stu_class = $("#edit_class").val();
          var section = $("#edit_section").val();
          var status = $("#edit_status").val();

          if (fname && lname && stu_class && section && status) {
            $.ajax({
              type: "POST",
              url: "Crud/code.php",
              data: {
                checking_update: true,
                stu_id: stu_id,
                fname: fname,
                lname: lname,
                class: stu_class,
                section: section,
                status: status,
              },
              success: function (response) {
                $("#EditModal").modal("hide");

                $(".message-show").html(`
                        <div class="alert alert-success alert-dismissible fade show">
                            <strong>Updated!</strong> ${response}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    `);

                loaddata(1);
              },
            });
          } else {
            alert("Please fill all fields!");
          }
        });

        /* ===============================
               PAGINATION
            =============================== */

        $(document).on("click", ".page-link", function (e) {
          e.preventDefault();
          var page = $(this).data("page");
          var search = $("#search_input").val();
          var status = $("#status_filter").val();
          loaddata(page, search, status);
        });
      });

      /* ===============================
         Live Search
       ================================= */

      $("#search_btn").click(function () {
        var search = $("#search_input").val();
        loaddata(1, search);
      });

      /* ===============================
           Active & InActive STUDENT
          =============================== */

      $("#status_filter").change(function () {
        var status = $(this).val();
        var search = $("#search_input").val();
        loaddata(1, search, status);
      });
